{
  "framework_id": "pgs_2026",
  "system_type": "participatory_guarantee_system",
  "version": "1.0.0",
  "pgs_evaluation_criteria": {
    
    "/* --- 1. GENERAL INFORMATION --- */": {},
    "legal_form": { "type": "string", "required": true },
    "geographic_location": { "type": "enum", "choices": ["PLAIN", "HILL", "MOUNTAIN"] },
    "altitude_meters": { "type": "int", "fallback": null },
    "activity_start_year": { "type": "int", "required": true },
    "has_on_site_farm_shop": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "land_tenure_type": { "type": "enum", "choices": ["OWNERSHIP", "RENT", "LOAN_FOR_USE", "OTHER"] },
    "economic_sustenance_level": { "type": "enum", "choices": ["PRIMARY", "SECONDARY_PART_TIME"] },

    "/* --- 2. COMPANY STRUCTURE & LABOR MANAGEMENT --- */": {},
    "total_land_surface_sqm_or_ha": { "type": "string", "required": true },
    "cultivated_surface_hectares": { "type": "float", "fallback": 0.0 },
    "greenhouse_surface_sqm": { "type": "float", "fallback": 0.0 },
    "main_machinery_equipment": { "type": "text", "fallback": "" },
    "hr_family_workers_count": { "type": "int", "fallback": 0 },
    "hr_permanent_workers_count": { "type": "int", "fallback": 0 },
    "hr_seasonal_workers_count": { "type": "int", "fallback": 0 },
    "seasonal_employment_months_details": { "type": "string", "fallback": "" },
    "hr_agency_or_external_coop_workers_count": { "type": "int", "fallback": 0 },
    "applied_labor_contracts_type": { "type": "string", "required": true },
    "workers_living_on_site_count": { "type": "int", "fallback": 0 },
    "is_social_cooperative": { "type": "bool", "fallback": false },
    "social_coop_total_member_workers": { "type": "int", "fallback": null },
    "social_coop_disadvantaged_workers_l381": { "type": "int", "fallback": null },
    "social_coop_total_employees": { "type": "int", "fallback": null },
    "labor_self_certification_compliance_statement": { "type": "bool", "required": true, "must_be": true },

    "/* --- 3. METHOD OF PRODUCTION & CERTIFICATIONS --- */": {},
    "prevalent_production_method": { "type": "enum", "choices": ["CERTIFIED_ORGANIC", "BIODYNAMIC", "IN_CONVERSION", "INTEGRATED", "CONVENTIONAL"] },
    "has_official_organic_certification": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "organic_certification_body_name": { "type": "string", "fallback": "" },
    "organic_operator_code": { "type": "string", "fallback": "" },
    "organic_first_certification_year": { "type": "int", "fallback": null },
    "organic_last_inspection_date": { "type": "string", "fallback": "" },
    "previous_certification_bodies_change_reasons": { "type": "text", "fallback": "" },
    "non_certified_organic_rules_compliance_details": { "type": "text", "fallback": "" },
    "organic_choice_motivation_lacking_logo_reasons": { "type": "text", "fallback": "" },
    "conventional_integrated_chemical_inputs_log": { "type": "text", "fallback": "" },
    "production_method_ideal_motivation_gmo_opinion": { "type": "text", "required": true },
    "performs_periodic_chemical_analyses": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "last_chemical_analysis_date": { "type": "string", "fallback": "" },

    "/* --- 4. AGRONOMIC PRACTICES & ENVIRONMENTAL CONTEXT --- */": {},
    "irrigation_water_source": { "type": "string", "required": true },
    "soil_fertility_management_manure_type_source": { "type": "text", "required": true },
    "manure_fertilizer_quantity_per_hectare_crops": { "type": "text", "fallback": "" },
    "weed_control_methodology": { "type": "text", "required": true },
    "pest_insect_disease_control_methodology": { "type": "text", "required": true },
    "seeds_seedlings_origin_and_nature": { "type": "text", "required": true },
    "pollution_sources_proximity_risk": { "type": "array", "items": "string" },
    "pollution_source_distance_km_details": { "type": "text", "fallback": "" },
    "neighboring_farms_production_method": { "type": "string", "fallback": "" },
    "environmental_sustainability_energy_saving_features": { "type": "array", "items": "string" },

    "/* --- 5. CATALOG, LOGISTICS & ECONOMICS --- */": {},
    "offered_products_macro_categories": { "type": "array", "items": "string" },
    "transformation_entirely_in_house": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "third_party_processing_company_location_details": { "type": "text", "fallback": "" },
    "commercializes_third_party_products": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "third_party_products_revenue_percentage": { "type": "float", "fallback": 0.0 },
    "active_sales_channels": { "type": "array", "items": "string" },
    "farmers_markets_details_and_frequency": { "type": "text", "fallback": "" },
    "gas_delivery_mode": { "type": "enum", "choices": ["GAS_PICKUP", "PRODUCER_HOME_DELIVERY", "THIRD_PARTY_COURIER"] },
    "specific_delivery_conditions_minimum_order_costs": { "type": "text", "fallback": "" },
    "costs_transparency_and_transparent_price_agreement": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "fiscal_payment_mode": { "type": "enum", "choices": ["RECEIPT", "INVOICE", "SELF_INVOICE", "FEES_REPORT"] },
    "indicative_turnover_current_year": { "type": "string", "fallback": "" },
    "indicative_turnover_previous_year": { "type": "string", "fallback": "" },
    "indicative_turnover_year_minus_two": { "type": "string", "fallback": "" },

    "/* --- 6. PUBLIC SERVICES & SOLIDARITY ENGAGEMENT --- */": {},
    "gas_presenter_name": { "type": "string", "required": true },
    "public_connected_activities": { "type": "array", "items": "string" },
    "ideal_gas_visit_period": { "type": "string", "fallback": "" },
    "active_or_past_gas_network_collaborations": { "type": "text", "fallback": "" },
    "ethical_social_practices_territorial_impact": { "type": "bool", "mapping": { "YES": 1, "NO": 0 } },
    "ethical_practices_specific_types": { "type": "array", "items": "string" },

    "/* --- 7. COMMITMENTS & SIGN-OFF --- */": {},
    "commitment_gas_charter_of_intents_coherence": { "type": "bool", "required": true, "must_be": true },
    "commitment_allow_gas_inspection_visits": { "type": "bool", "required": true, "must_be": true },
    "commitment_regular_updates_certs_price_lists": { "type": "bool", "required": true, "must_be": true },
    "commitment_personal_data_processing_authorization": { "type": "bool", "required": true, "must_be": true }
  },
  "pgs_workflow_stages": {
    "stages": {
      "producer_self_assessment": { "order": 1, "requires_fields": ["labor_self_certification_compliance_statement", "soil_fertility_management_manure_type_source"] },
      "gas_peer_visit_verification": { "order": 2, "mandatory": true, "requires_verification_of": ["weed_control_methodology", "pollution_sources_proximity_risk"] },
      "network_approval_deliberation": { "order": 3, "consensus_required": "majority_vote" }
    }
  }
}
